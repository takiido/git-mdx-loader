{
  "name": "git-mdx-loader",
  "version": "0.3.3",
  "description": "cache github article lists in next.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.3",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takiido/git-mdx-loader.git"
  },
  "keywords": [
    "github",
    "markdown",
    "mdx",
    "nextjs",
    "react",
    "content",
    "posts",
    "content-source",
    "content-loader",
    "typescript"
  ],
  "author": "takiido",
  "license": "MIT",
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "react": "^18 || ^19"
  }
}
